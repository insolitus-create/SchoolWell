---
import Base from '../../layouts/Base.astro';
import { locales, localePath, withBase, type Locale } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = ui[lang];

const sections = [
  {
    href: localePath(lang, 'cards/'),
    title: t.home.cardsTitle,
    desc: t.home.cardsDesc,
    image: withBase('cards/back-blue.png'),
  },
  {
    href: localePath(lang, 'gallery/'),
    title: t.home.galleryTitle,
    desc: t.home.galleryDesc,
    image: withBase('cards/blue/1.png'),
  },
  {
    href: localePath(lang, 'activities/'),
    title: t.home.activitiesTitle,
    desc: t.home.activitiesDesc,
    image: withBase('cards/back-green.png'),
  },
];
---

<Base lang={lang} title={t.siteName} description={t.home.lead}>
  <section class="bg-navy-800 py-14 text-white">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">{t.siteName}</h1>
      <p class="mt-3 text-xl font-medium text-leaf-400">{t.tagline}</p>
      <p class="mx-auto mt-5 max-w-2xl text-navy-100">{t.home.lead}</p>
    </div>
  </section>

  <section class="mx-auto grid max-w-5xl gap-6 px-4 py-12 sm:grid-cols-3">
    {
      sections.map((s) => (
        <a
          href={s.href}
          class="group flex flex-col overflow-hidden rounded-2xl border border-navy-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
        >
          <div class="flex h-44 items-center justify-center bg-navy-100/60 py-4">
            <img
              src={s.image}
              alt=""
              class="h-full rounded-lg shadow-md transition group-hover:scale-105"
            />
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h2 class="text-lg font-bold">{s.title}</h2>
            <p class="mt-2 flex-1 text-sm text-navy-700">{s.desc}</p>
            <span class="mt-4 font-semibold text-leaf-600 group-hover:text-leaf-700">
              {t.home.open} →
            </span>
          </div>
        </a>
      ))
    }
  </section>
</Base>
