---
import '../styles/global.css';
import Header from '../components/Header.astro';
import { locales, switchLocalePath, withBase, type Locale } from '../i18n/utils';
import { ui } from '../i18n/ui';

interface Props {
  lang: Locale;
  title: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const t = ui[lang];
const pageTitle = title === t.siteName ? title : `${title} · ${t.siteName}`;
const desc = description ?? t.tagline;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    {
      locales.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={new URL(switchLocalePath(Astro.url.pathname, l), Astro.site)}
        />
      ))
    }
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang} />
  </head>
  <body class="flex min-h-dvh flex-col bg-navy-50 text-navy-900">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-navy-100 py-6 text-center text-sm text-navy-600">
      {t.siteName} · {t.tagline}
    </footer>
  </body>
</html>
